/**
  * @brief  Redirect printf to huart3 (Joystick Port) to avoid HAL conflict
  */
int _write(int file, char *ptr, int len)
{
  for (int i = 0; i < len; i++)
  {
    while (!(huart3.Instance->ISR & UART_FLAG_TXE));
    huart3.Instance->TDR = ptr[i];
  }
  return len;
}

