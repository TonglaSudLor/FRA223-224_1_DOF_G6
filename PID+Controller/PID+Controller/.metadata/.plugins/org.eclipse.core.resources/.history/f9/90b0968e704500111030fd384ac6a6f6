  /* USER CODE BEGIN 2 */
  Motor_Init();
  Motor_SetVoltageLimit(12.0f, 12.0f);
  Motor_SetMotionProfile(2000.0f, 1000.0f, 0.8f);

  memset(registerFrame, 0, sizeof(registerFrame));
  registerFrame[0].U16 = 22881;

  hmodbus.huart = &hlpuart1;
